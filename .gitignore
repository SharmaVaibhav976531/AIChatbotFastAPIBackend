# ==========================================
# Python Bytecode & Cache
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Virtual Environments
# ==========================================
venv/
.venv/
env/
vir_env/
ENV/

# ==========================================
# Environment Variables (contains API keys)
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# IDE & Editor Settings
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==========================================
# OS Generated Files
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
